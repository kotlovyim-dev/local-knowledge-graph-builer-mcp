# LKGB Configuration
# Database path (default: ./data/lkgb.sqlite)
DATABASE_PATH=./data/lkgb.sqlite

# Obsidian vault path
VAULT_PATH=C:/Users/you/ObsidianVault

# Code directories to index (comma-separated)
CODE_PATHS=C:/projects/my-app/src

# Ollama embedding settings (optional — soft linking disabled without Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Similarity threshold for soft linking (0.0 - 1.0)
SIMILARITY_THRESHOLD=0.75
