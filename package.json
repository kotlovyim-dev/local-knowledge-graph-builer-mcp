{
  "name": "lkgb-mcp",
  "version": "0.1.0",
  "description": "Local Knowledge Graph Builder — MCP server that builds a semantic graph between documentation and code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "knowledge-graph",
    "obsidian",
    "semantic-search",
    "local-first"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
